# Required
GHCR_OWNER=baisikkel
POSTGRES_PASSWORD=changeme

# Optional
POSTGRES_DB=cyclerouteplanner
POSTGRES_USER=postgres
BACKEND_HOST_PORT=18080

# Image tags (set by CI or manually)
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest

# Optional upstream/source tuning
OSM_OVERPASS_BASE_URL=https://overpass-api.de/api
GEO_DEFAULT_BBOX_SOUTH=59.30
GEO_DEFAULT_BBOX_WEST=24.50
GEO_DEFAULT_BBOX_NORTH=59.52
GEO_DEFAULT_BBOX_EAST=24.93
GEO_OVERPASS_TIMEOUT_SECONDS=25
GEO_TALLINN_SOURCE_URL=https://gis.tallinn.ee/arcgis/rest/services/Rattateed/MapServer/0/query?where=1%3D1&outFields=*&f=geojson
GEO_TALLINN_SOURCE_LAYER=tallinn_open_data
GEO_TALLINN_FEATURE_ID_PROPERTY=id
GEO_TALLINN_FEATURE_NAME_PROPERTY=name

# Better Stack Logs
BETTERSTACK_SOURCE_TOKEN=your-source-token-here
BETTERSTACK_NGINX_SOURCE_TOKEN=your-nginx-source-token-here

# BRouter routing engine (passed to backend container)
# ROUTING_BROUTER_BASE_URL=http://brouter:17777/brouter
